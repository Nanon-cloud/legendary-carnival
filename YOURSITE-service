<div class="wrap">
  <div class="card">
    <h1>ฝึกพยัญชนะไทย (Thai Consonant Drill)</h1>
    <p class="sub">เลือก “ชื่อ” ของพยัญชนะที่แสดง (ผิดได้ 3 ครั้ง = 3 หัวใจ)</p>

    <!-- Start screen -->
    <div id="startScreen" class="start-screen">
      <div class="start-box">
        <label for="nicknameInput" class="label">Please enter your nickname before starting the quiz</label>
        <input
          id="nicknameInput"
          class="input"
          type="text"
          placeholder="Enter your nickname"
          maxlength="30"
        />
        <button id="startBtn" class="btn primary" type="button">Start Quiz</button>
        <div id="startMessage" class="small-note"></div>
      </div>
    </div>

    <!-- Quiz screen -->
    <div id="quizScreen" class="hidden">
      <div class="topbar">
        <div class="pill">
          <span>👤 Player:</span>
          <strong id="playerInfo">-</strong>
        </div>
        <div class="pill">
          <span>❤️ Lives:</span>
          <span class="hearts" id="hearts"></span>
        </div>
        <div class="pill"><span>Score:</span> <strong id="score">0</strong></div>
        <div class="pill"><span>Remaining:</span> <strong id="remaining">0</strong></div>
      </div>

      <div class="quiz">
        <div class="prompt">
          <p class="big" id="currentChar">ก</p>
          <p class="question" id="questionText">What is the name of this Thai consonant?</p>
        </div>

        <div class="grid" id="choices"></div>

        <div class="feedback" id="feedback">Enter your nickname first to begin</div>

        <div class="actions">
          <button class="btn primary" id="nextBtn" type="button" disabled>Next</button>
          <button class="btn danger" id="restartBtn" type="button">Restart</button>
        </div>
      </div>
    </div>
  </div>
</div>
