<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Thai Consonant Drill</title>
  <style>
    :root{
      --bg:#050b16;
      --panel:#0d1830;
      --panel-2:#15233f;
      --panel-3:#1c2942;
      --border:rgba(255,255,255,.10);
      --text:#eaf1ff;
      --muted:#b8c4df;
      --green:#46d17d;
      --green-bg:rgba(70,209,125,.14);
      --red:#ff5c7c;
      --red-bg:rgba(255,92,124,.14);
      --pill:#23314b;
      --shadow:0 18px 50px rgba(0,0,0,.35);
    }

    * { box-sizing: border-box; }

    body{
      margin:0;
      font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      background: radial-gradient(circle at top, #0a1730 0%, #050b16 45%, #040812 100%);
      color:var(--text);
      min-height:100vh;
      display:flex;
      justify-content:center;
      padding:22px;
    }

    .shell{
      width:min(100%, 900px);
    }

    .card{
      background:linear-gradient(180deg, rgba(15,27,53,.96), rgba(9,19,41,.96));
      border:1px solid var(--border);
      border-radius:28px;
      padding:20px;
      box-shadow:var(--shadow);
    }

    .title{
      font-size:20px;
      font-weight:800;
      margin:0 0 2px 0;
    }

    .subtitle{
      margin:0 0 16px 0;
      color:var(--muted);
      font-size:14px;
      font-weight:600;
    }

    .hidden{
      display:none !important;
    }

    .start-box{
      background:rgba(255,255,255,.04);
      border:1px solid var(--border);
      border-radius:18px;
      padding:18px;
      display:flex;
      flex-direction:column;
      gap:12px;
      margin-bottom:16px;
    }

    .start-label{
      font-size:15px;
      font-weight:700;
      color:var(--text);
    }

    .start-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .input{
      flex:1 1 240px;
      min-width:220px;
      padding:13px 14px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.12);
      background:#111c33;
      color:var(--text);
      font-size:15px;
      outline:none;
    }

    .input::placeholder{
      color:#8fa0c4;
    }

    .btn{
      border:none;
      border-radius:14px;
      padding:12px 18px;
      font-size:15px;
      font-weight:800;
      cursor:pointer;
      transition:.15s ease;
    }

    .btn:hover{
      transform:translateY(-1px);
      opacity:.96;
    }

    .btn:disabled{
      opacity:.6;
      cursor:not-allowed;
      transform:none;
    }

    .btn-primary{
      background:#177df0;
      color:white;
      box-shadow:0 8px 20px rgba(23,125,240,.22);
    }

    .btn-next{
      background:var(--green-bg);
      color:#dff9ea;
      border:1px solid rgba(70,209,125,.35);
    }

    .btn-restart{
      background:var(--red-bg);
      color:#ffe3ea;
      border:1px solid rgba(255,92,124,.35);
    }

    .start-note{
      font-size:13px;
      color:var(--muted);
      font-weight:600;
    }

    .topbar{
      display:grid;
      grid-template-columns:repeat(5, max-content);
      gap:12px;
      align-items:center;
      justify-content:space-between;
      margin-bottom:16px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      background:var(--pill);
      border:1px solid rgba(255,255,255,.10);
      color:var(--text);
      border-radius:999px;
      padding:10px 14px;
      font-size:13px;
      font-weight:800;
      white-space:nowrap;
    }

    .hearts{
      display:inline-flex;
      gap:6px;
      align-items:center;
    }

    .heart{
      font-size:18px;
      line-height:1;
    }

    .alive{ color:#ff4f73; }
    .dead{ color:rgba(255,255,255,.25); }

    .toggle{
      cursor:pointer;
      user-select:none;
    }

    .quiz-box{
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .prompt{
      background:var(--panel-3);
      border:1px dashed rgba(255,255,255,.14);
      border-radius:20px;
      min-height:200px;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:18px;
    }

    .big-char{
      font-size:112px;
      line-height:1;
      font-weight:900;
      margin:0 0 10px 0;
      color:#eef3ff;
    }

    .question{
      margin:0;
      font-size:15px;
      color:#d5def2;
      font-weight:700;
    }

    .choices{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    .choice{
      width:100%;
      background:#202e47;
      color:var(--text);
      border:1px solid rgba(255,255,255,.10);
      border-radius:18px;
      padding:18px 14px;
      font-size:18px;
      font-weight:800;
      cursor:pointer;
      transition:.15s ease;
    }

    .choice:hover{
      transform:translateY(-1px);
      background:#263652;
    }

    .choice:disabled{
      opacity:.85;
      cursor:not-allowed;
      transform:none;
    }

    .feedback{
      min-height:58px;
      padding:16px 14px;
      border-radius:16px;
      background:#081328;
      border:1px solid rgba(255,255,255,.10);
      color:#f0f4ff;
      font-size:16px;
      font-weight:700;
      display:flex;
      align-items:center;
    }

    .feedback.ok{
      color:#dff9ea;
      border-color:rgba(70,209,125,.25);
    }

    .feedback.bad{
      color:#ffe3ea;
      border-color:rgba(255,92,124,.25);
    }

    .actions{
      display:flex;
      justify-content:center;
      gap:10px;
      flex-wrap:wrap;
      margin-top:4px;
    }

    .footer{
      text-align:center;
      color:var(--muted);
      font-size:13px;
      font-weight:700;
      padding-top:4px;
    }

    @media (max-width: 840px){
      .topbar{
        grid-template-columns:repeat(2, 1fr);
        justify-content:stretch;
      }
      .pill{
        justify-content:center;
      }
    }

    @media (max-width: 620px){
      body{padding:14px;}
      .card{padding:16px;}
      .choices{grid-template-columns:1fr;}
      .topbar{grid-template-columns:1fr;}
      .big-char{font-size:88px;}
    }
  </style>
</head>
<body>
  <div class="shell">
    <div class="card">
      <h1 class="title">ฝึกพยัญชนะไทย (Thai Consonant Drill)</h1>
      <p class="subtitle">เลือก “ชื่อ” ของพยัญชนะที่แสดง (ผิดได้ 3 ครั้ง = 3 หัวใจ)</p>

      <div id="startScreen" class="start-box">
        <div class="start-label">Please enter your nickname before starting the quiz</div>
        <div class="start-row">
          <input id="nicknameInput" class="input" type="text" placeholder="Your nickname" maxlength="30">
          <button id="startBtn" class="btn btn-primary" type="button">Start Quiz</button>
        </div>
        <div id="startMessage" class="start-note">Your start counter will increase every time you begin the quiz.</div>
      </div>

      <div id="quizScreen">
        <div class="topbar">
          <div class="pill">👤 Player: <strong id="playerInfo">-</strong></div>
          <div class="pill">❤️ ชีวิต: <span id="hearts" class="hearts"></span></div>
          <div class="pill">คะแนน: <strong id="score">0</strong></div>
          <div class="pill">เหลือ: <strong id="remaining">0</strong></div>
          <label class="pill toggle">
            <input id="showPair" type="checkbox" />
            <span>แสดงแบบ “ก ไก่”</span>
          </label>
        </div>

        <div class="quiz-box">
          <div class="prompt">
            <p id="currentChar" class="big-char">ก</p>
            <p id="questionText" class="question">พยัญชนะนี้ชื่อว่าอะไร?</p>
          </div>

          <div id="choices" class="choices"></div>

          <div id="feedback" class="feedback">กรอกชื่อก่อนเริ่ม</div>

          <div class="actions">
            <button id="nextBtn" class="btn btn-next" type="button" disabled>ข้อถัดไป</button>
            <button id="restartBtn" class="btn btn-restart" type="button">เริ่มใหม่</button>
          </div>

          <div class="footer">ระบบจะ “ไม่ถามซ้ำ” ตัวที่คุณตอบถูกแล้ว ✅</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const ALL = [
      { ch: "ก", name: "ไก่" },   { ch: "ข", name: "ไข่" },     { ch: "ฃ", name: "ขวด" },
      { ch: "ค", name: "ควาย" },  { ch: "ฅ", name: "คน" },     { ch: "ฆ", name: "ระฆัง" },
      { ch: "ง", name: "งู" },    { ch: "จ", name: "จาน" },    { ch: "ฉ", name: "ฉิ่ง" },
      { ch: "ช", name: "ช้าง" },  { ch: "ซ", name: "โซ่" },    { ch: "ฌ", name: "เฌอ" },
      { ch: "ญ", name: "หญิง" },  { ch: "ฎ", name: "ชฎา" },    { ch: "ฏ", name: "ปฏัก" },
      { ch: "ฐ", name: "ฐาน" },   { ch: "ฑ", name: "มณโฑ" },   { ch: "ฒ", name: "ผู้เฒ่า" },
      { ch: "ณ", name: "เณร" },   { ch: "ด", name: "เด็ก" },   { ch: "ต", name: "เต่า" },
      { ch: "ถ", name: "ถุง" },   { ch: "ท", name: "ทหาร" },   { ch: "ธ", name: "ธง" },
      { ch: "น", name: "หนู" },   { ch: "บ", name: "ใบไม้" },  { ch: "ป", name: "ปลา" },
      { ch: "ผ", name: "ผึ้ง" },  { ch: "ฝ", name: "ฝา" },     { ch: "พ", name: "พาน" },
      { ch: "ฟ", name: "ฟัน" },   { ch: "ภ", name: "สำเภา" },  { ch: "ม", name: "ม้า" },
      { ch: "ย", name: "ยักษ์" }, { ch: "ร", name: "เรือ" },   { ch: "ล", name: "ลิง" },
      { ch: "ว", name: "แหวน" },  { ch: "ศ", name: "ศาลา" },   { ch: "ษ", name: "ฤๅษี" },
      { ch: "ส", name: "เสือ" },  { ch: "ห", name: "หีบ" },    { ch: "ฬ", name: "จุฬา" },
      { ch: "อ", name: "อ่าง" },  { ch: "ฮ", name: "นกฮูก" }
    ];

    const startScreen = document.getElementById("startScreen");
    const nicknameInput = document.getElementById("nicknameInput");
    const startBtn = document.getElementById("startBtn");
    const startMessage = document.getElementById("startMessage");
    const playerInfoEl = document.getElementById("playerInfo");

    const heartsEl = document.getElementById("hearts");
    const scoreEl = document.getElementById("score");
    const remainingEl = document.getElementById("remaining");
    const currentCharEl = document.getElementById("currentChar");
    const questionTextEl = document.getElementById("questionText");
    const choicesEl = document.getElementById("choices");
    const feedbackEl = document.getElementById("feedback");
    const nextBtn = document.getElementById("nextBtn");
    const restartBtn = document.getElementById("restartBtn");
    const showPairEl = document.getElementById("showPair");

    let current = null;
    let remaining = [];
    let lives = 3;
    let score = 0;
    let locked = false;
    let lastAsked = null;
    let nickname = "";
    let startCount = 0;

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function renderHearts() {
      heartsEl.innerHTML = "";
      for (let i = 0; i < 3; i++) {
        const span = document.createElement("span");
        span.className = "heart " + (i < lives ? "alive" : "dead");
        span.textContent = "♥";
        heartsEl.appendChild(span);
      }
    }

    function updateStats() {
      scoreEl.textContent = score;
      remainingEl.textContent = remaining.length;
      renderHearts();
    }

    function setFeedback(text, cls = "") {
      feedbackEl.className = "feedback" + (cls ? " " + cls : "");
      feedbackEl.innerHTML = text;
    }

    function disableChoices() {
      [...choicesEl.querySelectorAll(".choice")].forEach(btn => btn.disabled = true);
    }

    function buildChoices() {
      const correct = current;
      const pool = ALL.filter(x => x.ch !== correct.ch);
      shuffle(pool);
      const wrongs = pool.slice(0, 3);
      const options = shuffle([correct, ...wrongs]);

      choicesEl.innerHTML = "";
      options.forEach(opt => {
        const btn = document.createElement("button");
        btn.className = "choice";
        btn.type = "button";
        btn.textContent = showPairEl.checked ? `${opt.ch} ${opt.name}` : opt.name;
        btn.addEventListener("click", () => choose(opt));
        choicesEl.appendChild(btn);
      });
    }

    function pickNext() {
      if (!nickname) {
        currentCharEl.textContent = "ก";
        questionTextEl.textContent = "พยัญชนะนี้ชื่อว่าอะไร?";
        choicesEl.innerHTML = "";
        setFeedback("กรอกชื่อก่อนเริ่ม");
        nextBtn.disabled = true;
        return;
      }

      if (remaining.length === 0) {
        current = null;
        currentCharEl.textContent = "🎉";
        questionTextEl.textContent = "ตอบครบทุกตัวแล้ว";
        choicesEl.innerHTML = "";
        nextBtn.disabled = true;
        setFeedback(`เก่งมาก ${nickname}! คุณตอบถูกครบทั้งหมดแล้ว ✅`, "ok");
        return;
      }

      let candidates = remaining;
      if (remaining.length > 1 && lastAsked) {
        const filtered = remaining.filter(x => x.ch !== lastAsked.ch);
        if (filtered.length > 0) candidates = filtered;
      }

      current = candidates[Math.floor(Math.random() * candidates.length)];
      lastAsked = current;
      currentCharEl.textContent = current.ch;
      questionTextEl.textContent = "พยัญชนะนี้ชื่อว่าอะไร?";
      buildChoices();
      nextBtn.disabled = true;
      locked = false;
      setFeedback("เลือกคำตอบที่ถูกต้อง");
    }

    function choose(opt) {
      if (locked || !current) return;
      locked = true;

      const correct = opt.ch === current.ch;
      disableChoices();

      if (correct) {
        remaining = remaining.filter(x => x.ch !== current.ch);
        score += 1;
        updateStats();
        setFeedback(`ถูกต้อง ✅ <b>${current.ch} ${current.name}</b>`, "ok");
        nextBtn.disabled = false;
        return;
      }

      lives -= 1;
      updateStats();

      if (lives <= 0) {
        currentCharEl.textContent = "💔";
        questionTextEl.textContent = "ลองเริ่มใหม่อีกครั้ง";
        nextBtn.disabled = true;
        setFeedback(`ผิด ❌ คำตอบที่ถูกคือ <b>${current.ch} ${current.name}</b><br><br><b>เกมจบแล้ว</b> (ผิดครบ 3 ครั้ง)`, "bad");
        return;
      }

      setFeedback(`ผิด ❌ คำตอบที่ถูกคือ <b>${current.ch} ${current.name}</b> (เหลืออีก ${lives} หัวใจ)`, "bad");
      nextBtn.disabled = false;
    }

    function updatePlayerInfo() {
      playerInfoEl.textContent = nickname ? `${nickname} | starts: ${startCount}` : "-";
    }

    function resetQuiz() {
      remaining = ALL.map(x => ({ ...x }));
      lives = 3;
      score = 0;
      locked = false;
      lastAsked = null;
      updateStats();
      pickNext();
    }

    function startQuiz() {
      const name = nicknameInput.value.trim();
      if (!name) {
        startMessage.textContent = "You must enter your name before starting.";
        return;
      }

      nickname = name;
      startCount += 1;
      updatePlayerInfo();

      startScreen.classList.add("hidden");
      setFeedback(`Welcome ${nickname}! This is start number ${startCount}.`, "ok");
      resetQuiz();
    }

    function restartQuiz() {
      if (!nickname) {
        setFeedback("กรอกชื่อก่อนเริ่ม");
        return;
      }
      startCount += 1;
      updatePlayerInfo();
      resetQuiz();
      setFeedback(`Welcome back ${nickname}! This is start number ${startCount}.`, "ok");
    }

    startBtn.addEventListener("click", startQuiz);
    restartBtn.addEventListener("click", restartQuiz);
    nextBtn.addEventListener("click", pickNext);
    showPairEl.addEventListener("change", () => {
      if (current) buildChoices();
    });
    nicknameInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") startQuiz();
    });

    updatePlayerInfo();
    updateStats();
    pickNext();
  </script>
</body>
</html>
